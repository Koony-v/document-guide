async function exportMySettings() {
  const data = {
    type: 'mySettings',
    version: 1,
    savedAt: new Date().toLocaleDateString('ko-KR'),
    siteInfo,
    presets
  };
  const json = JSON.stringify(data, null, 2);

  // 다른 이름으로 저장 창 (크롬 지원)
  if (window.showSaveFilePicker) {
    try {
      const fileHandle = await window.showSaveFilePicker({
        suggestedName: '내설정_백업.json',
        types: [{ description: 'JSON 파일', accept: { 'application/json': ['.json'] } }]
      });
      const writable = await fileHandle.createWritable();
      await writable.write(json);
      await writable.close();
      showToast('💾 내 설정 저장 완료!', 'blue');
    } catch(e) {
      if (e.name !== 'AbortError') showToast('⚠️ 저장에 실패했어요', 'green');
    }
  } else {
    // 미지원 브라우저 폴백
    const blob = new Blob([json], {type:'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = '내설정_백업.json'; a.target='_blank'; document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('💾 내 설정 저장 완료!', 'blue');
  }
}

function importMySettings(event) {
  const file = event.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const data = JSON.parse(e.target.result);
      if (data.type !== 'mySettings') { showToast('⚠️ 개인 설정 파일이 아니에요'); return; }
      if (data.siteInfo) { siteInfo = {...DEFAULT_INFO, ...data.siteInfo}; saveInfo(); }
      if (data.presets)  { presets = data.presets; savePresets(); renderPresets(); }
      document.getElementById('setFirmName').value  = siteInfo.firmName  || '';
      document.getElementById('setStaffName').value = siteInfo.staffName || '';
      document.getElementById('setPhone').value     = siteInfo.phone     || '';
      document.getElementById('setFax').value       = siteInfo.fax       || '';
      document.getElementById('setAddress').value   = siteInfo.address   || '';
      document.getElementById('setGreeting').value  = siteInfo.greeting  || DEFAULT_INFO.greeting;
      document.getElementById('setFooter').value    = siteInfo.footer    || DEFAULT_INFO.footer;
