// ── 미리보기 히스토리 (되돌리기/앞으로가기) ──
let previewHistory = [];
let currentSessionDocs = []; // 현재 세션에서 추가한 서류 ID 목록
let previewFuture  = [];

function saveHistory() {
  const preview = document.getElementById('kakaoPreview');
  const text = preview.innerText || preview.textContent || '';
  if (previewHistory.length === 0 || previewHistory[previewHistory.length-1] !== text) {
    previewHistory.push(text);
    previewFuture = []; // 새 변경 시 앞으로가기 초기화
    if (previewHistory.length > 50) previewHistory.shift();
  }
  updateHistoryBtns();
}

function updateHistoryBtns() {
  const undoBtn = document.getElementById('undoBtn');
  const redoBtn = document.getElementById('redoBtn');
  if (undoBtn) { undoBtn.disabled = previewHistory.length <= 1; undoBtn.style.opacity = previewHistory.length <= 1 ? '0.4' : '1'; }
  if (redoBtn) { redoBtn.disabled = previewFuture.length === 0; redoBtn.style.opacity = previewFuture.length === 0 ? '0.4' : '1'; }
}

function undoPreview() {
  if (previewHistory.length <= 1) return;
  const preview = document.getElementById('kakaoPreview');
  previewFuture.push(previewHistory.pop());
  preview.textContent = previewHistory[previewHistory.length-1] || '';
  updateHistoryBtns();
}

function redoPreview() {
  if (previewFuture.length === 0) return;
  const preview = document.getElementById('kakaoPreview');
  const next = previewFuture.pop();
  previewHistory.push(next);
  preview.textContent = next;
  updateHistoryBtns();
}

function addToMessage(id) {
  const d = allDocs.find(d => String(d.id) === String(id));
  if (!d) return;
  const preview = document.getElementById('kakaoPreview');
  const current = (preview.innerText || preview.textContent || '').trimEnd();
  const newLine = '■ ' + d.name + '\n   → ' + d.method;

  if (!current || current.includes('서류를 클릭하면') || current.includes('서류를 선택하면')) {
    preview.textContent = buildGreeting(siteInfo) + '\n아래 서류를 준비해 주시면 됩니다.\n\n' + newLine + '\n\n' + buildFooter(siteInfo);
  } else {
    const footerIdx = current.indexOf('\n※');
    if (footerIdx !== -1) {
      const beforeFooter = current.slice(0, footerIdx).trimEnd();
      const footer = current.slice(footerIdx).trimStart();
      preview.textContent = beforeFooter + '\n' + newLine + '\n\n' + footer;
    } else {
      preview.textContent = current.trimEnd() + '\n' + newLine;
    }
  }
  // 현재 형식으로 새 서류도 변환
  if (currentFormat !== 'orig') {
    const preview2 = document.getElementById('kakaoPreview');
    const cur2 = (preview2.innerText || preview2.textContent || '').trim();
    preview2.textContent = convertFormat(getOrigText(cur2), currentFormat);
  }
  if (!currentSessionDocs.includes(d.id)) currentSessionDocs.push(d.id);
  showToast('✅ 메시지에 추가됨', 'blue');
  saveHistory();
}

