// ── 로드/저장 ──
function loadAll() {
  try { const d = localStorage.getItem(DOCS_KEY); allDocs = d ? JSON.parse(d) : JSON.parse(JSON.stringify(DEFAULT_DOCS)).map(d=>({...d,checked:false})); } catch(e) { allDocs = JSON.parse(JSON.stringify(DEFAULT_DOCS)).map(d=>({...d,checked:false})); }
  try { const t = localStorage.getItem(TYPES_KEY); clientTypes = t ? JSON.parse(t) : JSON.parse(JSON.stringify(DEFAULT_TYPES)); } catch(e) { clientTypes = JSON.parse(JSON.stringify(DEFAULT_TYPES)); }
  try { const i = localStorage.getItem(INFO_KEY); if (i) siteInfo = {...DEFAULT_INFO,...JSON.parse(i)}; } catch(e) {}
  try { const p = localStorage.getItem(PRESET_KEY); presets = p ? JSON.parse(p) : JSON.parse(JSON.stringify(DEFAULT_PRESETS)); } catch(e) { presets = JSON.parse(JSON.stringify(DEFAULT_PRESETS)); }
  try { const c = localStorage.getItem(CAT_KEY);    if (c) cats = JSON.parse(c); else cats = JSON.parse(JSON.stringify(DEFAULT_CATS)); } catch(e) { cats = JSON.parse(JSON.stringify(DEFAULT_CATS)); }
  // ID 충돌 방지: 기존 c*** ID 중 최대값보다 크게 설정
  const usedIds = allDocs.map(d => String(d.id)).filter(id => id.startsWith('c')).map(id => parseInt(id.slice(1))).filter(n => !isNaN(n));
  if (usedIds.length > 0) nextDocId = Math.max(...usedIds) + 1;
}

// ── 로드/저장 ──
function saveDocs()    { try { localStorage.setItem(DOCS_KEY,   JSON.stringify(allDocs));     } catch(e) {} }
function saveTypes()   { try { localStorage.setItem(TYPES_KEY,  JSON.stringify(clientTypes)); } catch(e) {} }
function saveInfo()    { try { localStorage.setItem(INFO_KEY,   JSON.stringify(siteInfo));    } catch(e) {} }
function savePresets() { try { localStorage.setItem(PRESET_KEY, JSON.stringify(presets));     } catch(e) {} }
function saveCats()    { try { localStorage.setItem(CAT_KEY,    JSON.stringify(cats));        } catch(e) {} }

function showToast(msg, type='green') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = `toast ${type} show`;
  setTimeout(() => t.classList.remove('show'), 2200);
}

// ── 내보내기 / 불러오기 ──
function exportDocs() {
  const data = { version:5, exportedAt: new Date().toLocaleDateString('ko-KR'), allDocs, clientTypes, cats };
  const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href=url; a.download='서류목록_백업.json'; a.target='_blank'; document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('💾 서류목록_백업.json 저장 완료!','green');
}
function importDocs(event) {
  const file = event.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const data = JSON.parse(e.target.result);
      // 서류목록 / 카테고리 / 유형만 업데이트 (사무소 정보, 프리셋은 건드리지 않음)
      if (data.allDocs)     allDocs     = data.allDocs;
      if (data.clientTypes) clientTypes = data.clientTypes;
      if (data.cats)        cats        = data.cats;
      else                  cats        = JSON.parse(JSON.stringify(DEFAULT_CATS));
      // ID 충돌 방지
      const usedIds = allDocs.map(d=>String(d.id)).filter(id=>id.startsWith('c')).map(id=>parseInt(id.slice(1))).filter(n=>!isNaN(n));
      if (usedIds.length > 0) nextDocId = Math.max(...usedIds) + 1;
      saveDocs(); saveTypes(); saveCats();
      renderTypes(); renderAddTypeSelect(); renderEditTypeSelect();
      renderAddCatSelect(); renderEditCatSelect();
      renderChecklist(); renderPresets(); updatePreview();
      showToast('📂 서류 목록 업데이트 완료!','blue');
    } catch(e) { showToast('⚠️ 파일을 읽을 수 없습니다'); }
    event.target.value = '';
  };
  reader.readAsText(file);
}

// ── 유형 렌더링 ──
function renderTypes() {
  const grid = document.getElementById('typeGrid');
  grid.innerHTML = clientTypes.map(t =>
    `<button class="type-btn ${selectedType===t.id?'active':''}" onclick="selectType('${t.id}')">${t.emoji} ${t.name}</button>`
  ).join('');
  if (!clientTypes.find(t=>t.id===selectedType)) {
    selectedType = clientTypes[0]?.id || 'all';
  }
}

function renderAddTypeSelect() {
  const sel = document.getElementById('addType');
  sel.innerHTML = clientTypes.map(t =>
    `<option value="${t.id}">${t.emoji} ${t.name}</option>`
  ).join('');
}

function renderEditTypeCheckboxes(selectedTypes) {
  const container = document.getElementById('editTypeCheckboxes');
  if (!container) return;
  const types = clientTypes.filter(t => t.id !== 'all');
  const allChecked = types.every(t => (selectedTypes||[]).includes(t.id));
  container.innerHTML = `
    <label style="display:flex;align-items:center;gap:5px;padding:4px 8px;border:1.5px solid ${allChecked?'#6366f1':'#e5e7eb'};border-radius:6px;cursor:pointer;font-size:12px;font-weight:700;color:${allChecked?'#4f46e5':'#374151'};background:${allChecked?'#eef2ff':'#fff'};transition:all 0.1s;">
      <input type="checkbox" id="editTypeCheck_all_toggle" ${allChecked?'checked':''} style="accent-color:#6366f1;" onchange="toggleAllEditTypes(this.checked)">
      전체
    </label>` +
    types.map(t => `
    <label style="display:flex;align-items:center;gap:5px;padding:4px 8px;border:1.5px solid #e5e7eb;border-radius:6px;cursor:pointer;font-size:12px;font-weight:500;color:#374151;background:#fff;transition:all 0.1s;">
      <input type="checkbox" id="editTypeCheck_${t.id}" value="${t.id}"
        ${(selectedTypes||[]).includes(t.id) ? 'checked' : ''}
        style="accent-color:#6366f1;"
        onchange="updateEditTypeCheckStyle('${t.id}',this.checked);syncEditAllToggle()">
      ${t.emoji} ${t.name}
    </label>`).join('');
  types.forEach(t => updateEditTypeCheckStyle(t.id, (selectedTypes||[]).includes(t.id)));
}

let _editToggling = false;
function toggleAllEditTypes(checked) {
  if (_editToggling) return;
  _editToggling = true;
  const types = clientTypes.filter(t => t.id !== 'all');
  types.forEach(t => {
    const el = document.getElementById('editTypeCheck_' + t.id);
    if (el) { el.checked = checked; updateEditTypeCheckStyle(t.id, checked); }
  });
  const toggle = document.getElementById('editTypeCheck_all_toggle');
  if (toggle) toggle.checked = checked;
  const allLabel = toggle?.parentElement;
  if (allLabel) {
    allLabel.style.borderColor = checked ? '#6366f1' : '#e5e7eb';
    allLabel.style.background  = checked ? '#eef2ff' : '#fff';
    allLabel.style.color       = checked ? '#4f46e5' : '#374151';
    allLabel.style.fontWeight  = checked ? '700' : '500';
  }
  _editToggling = false;
}

function syncEditAllToggle() {
  if (_editToggling) return;
  const types = clientTypes.filter(t => t.id !== 'all');
  const allChecked = types.every(t => document.getElementById('editTypeCheck_' + t.id)?.checked);
  const toggle = document.getElementById('editTypeCheck_all_toggle');
