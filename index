// ── PDF 뷰어 탭 시스템 ──
let pdfTabs = [];        // [{name, url}]
let pdfActiveIdx = -1;
let pdfZoomLevel = 100;

function loadPdfView(event) {
  const file = event.target.files[0]; if (!file) return;
  const url  = URL.createObjectURL(file);
  const name = file.name.replace(/\.pdf$/i, '').replace(/_/g, ' ');

  // 같은 이름 파일 중복 방지
  const exists = pdfTabs.findIndex(t => t.name === name);
  if (exists >= 0) {
    switchPdfTab(exists);
  } else {
    pdfTabs.push({ name, url });
    switchPdfTab(pdfTabs.length - 1);
  }
  event.target.value = '';
  showToast('📄 ' + name + ' 열기 완료', 'blue');
}

function switchPdfTab(idx) {
  pdfActiveIdx  = idx;
  pdfZoomLevel  = 100;
  renderPdfTabs();
  renderPdfIframe();
  updateFavBtn();
}

function closePdfTab(idx, e) {
  e.stopPropagation();
  URL.revokeObjectURL(pdfTabs[idx].url);
  pdfTabs.splice(idx, 1);
  if (pdfTabs.length === 0) {
    pdfActiveIdx = -1;
    renderPdfTabs();
    document.getElementById('pdfEmpty').style.display = 'flex';
    document.getElementById('pdfZoomCtrl').style.display = 'none';
    const old = document.getElementById('pdfViewFrame');
    if (old) old.remove();
    return;
  }
  pdfActiveIdx = Math.min(idx, pdfTabs.length - 1);
  renderPdfTabs();
  renderPdfIframe();
}

function renderPdfTabs() {
  const bar = document.getElementById('pdfTabBar');
  if (!bar) return;
  if (pdfTabs.length === 0) { bar.style.display = 'none'; return; }
  bar.style.display = 'flex';
  bar.innerHTML = pdfTabs.map((t, i) => `
    <div onclick="switchPdfTab(${i})" style="
      display:flex;align-items:center;gap:5px;
      padding:4px 10px;border-radius:6px 6px 0 0;cursor:pointer;
      font-size:11px;font-weight:600;max-width:140px;
      background:${i===pdfActiveIdx?'#fff':'#2d3139'};
      color:${i===pdfActiveIdx?'#1a1d23':'#9ca3af'};
      border:${i===pdfActiveIdx?'2px solid #6366f1':'2px solid transparent'};
      border-bottom:${i===pdfActiveIdx?'2px solid #fff':'2px solid transparent'};
      margin-bottom:-2px;">
      <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100px;" title="${t.name}">${t.name}</span>
      <button onclick="closePdfTab(${i}, event)" style="
        width:14px;height:14px;border:none;background:${i===pdfActiveIdx?'#e5e7eb':'#3a3f4b'};
        color:${i===pdfActiveIdx?'#374151':'#9ca3af'};border-radius:50%;cursor:pointer;
        font-size:10px;line-height:1;flex-shrink:0;padding:0;">×</button>
    </div>`).join('');
}

function renderPdfIframe() {
  const wrap = document.getElementById('pdfIframeWrap');
  if (pdfActiveIdx < 0 || !pdfTabs[pdfActiveIdx]) return;
  document.getElementById('pdfEmpty').style.display = 'none';
  document.getElementById('pdfZoomCtrl').style.display = 'flex';
  document.getElementById('pdfZoomLabel').textContent = pdfZoomLevel + '%';

  const old = document.getElementById('pdfViewFrame');
  if (old) old.remove();

  const iframe = document.createElement('iframe');
  iframe.id = 'pdfViewFrame';
  iframe.style.cssText = 'border:none;display:block;transform-origin:top left;';
  const scale = pdfZoomLevel / 100;
  iframe.style.width     = (100 / scale) + '%';
  iframe.style.height    = (100 / scale) + '%';
  iframe.style.transform = `scale(${scale})`;
  iframe.src = pdfTabs[pdfActiveIdx].url + '#toolbar=1&zoom=' + pdfZoomLevel;
  wrap.appendChild(iframe);
}

function pdfZoom(delta) {
  if (pdfActiveIdx < 0) return;
  pdfZoomLevel = Math.min(200, Math.max(50, pdfZoomLevel + delta));
  document.getElementById('pdfZoomLabel').textContent = pdfZoomLevel + '%';
  const iframe = document.getElementById('pdfViewFrame');
  if (iframe) {
    const scale = pdfZoomLevel / 100;
    iframe.style.width     = (100 / scale) + '%';
    iframe.style.height    = (100 / scale) + '%';
    iframe.style.transform = `scale(${scale})`;
  }
}

function pdfZoomReset() {
  if (pdfActiveIdx >= 0) { pdfZoomLevel = 100; renderPdfIframe(); }
}
