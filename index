  };
  reader.readAsText(file);
}



// ── PDF 즐겨찾기 (IndexedDB) ──
const PDF_DB_NAME = 'pdfFavorites';
const PDF_DB_VER  = 1;
const PDF_STORE   = 'pdfs';
let pdfDb = null;

function openPdfDb() {
  return new Promise((resolve, reject) => {
    if (pdfDb) { resolve(pdfDb); return; }
    const req = indexedDB.open(PDF_DB_NAME, PDF_DB_VER);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(PDF_STORE)) {
        db.createObjectStore(PDF_STORE, { keyPath: 'name' });
      }
    };
    req.onsuccess = e => { pdfDb = e.target.result; resolve(pdfDb); };
    req.onerror   = e => reject(e);
  });
}

async function savePdfFav(name, blob) {
  const db = await openPdfDb();
  return new Promise((resolve, reject) => {
    const tx = db.transaction(PDF_STORE, 'readwrite');
    tx.objectStore(PDF_STORE).put({ name, blob, savedAt: Date.now() });
    tx.oncomplete = resolve;
    tx.onerror    = reject;
  });
}

async function deletePdfFav(name) {
  const db = await openPdfDb();
  return new Promise((resolve, reject) => {
    const tx = db.transaction(PDF_STORE, 'readwrite');
    tx.objectStore(PDF_STORE).delete(name);
    tx.oncomplete = resolve;
    tx.onerror    = reject;
  });
}

async function getAllPdfFavs() {
  const db = await openPdfDb();
  return new Promise((resolve, reject) => {
    const tx  = db.transaction(PDF_STORE, 'readonly');
    const req = tx.objectStore(PDF_STORE).getAll();
    req.onsuccess = () => resolve(req.result);
    req.onerror   = reject;
  });
}

async function loadPdfFavs() {
  try {
    const bar = document.getElementById('pdfFavBar');
    if (!bar) return;

    // 내장 PDF - IndexedDB 없이 항상 직접 표시
    const builtinHtml = DEFAULT_PDFS.map((pdf, i) =>
      `<div style="display:flex;align-items:center;gap:3px;background:#2d3139;border-radius:5px;padding:3px 4px 3px 8px;max-width:200px;">
        <button onclick="loadBuiltinPdf(${i})"
          style="background:none;border:none;color:#fbbf24;font-size:11px;font-weight:600;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;padding:0;"
          title="${pdf.name}">⭐ ${pdf.name}</button>
      </div>`
    ).join('');

    // 사용자가 직접 추가한 PDF (IndexedDB)
    const favs = await getAllPdfFavs();
    const defaultNames = new Set(DEFAULT_PDFS.map(p => p.name));
    const userHtml = favs.filter(f => !defaultNames.has(f.name)).map(f =>
      `<div style="display:flex;align-items:center;gap:3px;background:#2d3139;border-radius:5px;padding:3px 4px 3px 8px;max-width:200px;">
        <button onclick="loadPdfFromFav('${f.name.replace(/'/g,"\'")}')"
          style="background:none;border:none;color:#fbbf24;font-size:11px;font-weight:600;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:150px;padding:0;"
          title="${f.name}">⭐ ${f.name}</button>
        <button onclick="removePdfFav('${f.name.replace(/'/g,"\'")}')"
          style="background:none;border:none;color:#6b7280;font-size:12px;cursor:pointer;padding:0;flex-shrink:0;">×</button>
      </div>`
    ).join('');

    const allHtml = userHtml + (userHtml && builtinHtml ? '<div style="width:1px;background:#3a3f4b;margin:2px 2px;"></div>' : '') + builtinHtml;
    bar.style.display = allHtml ? 'flex' : 'none';
    bar.innerHTML = allHtml;
  } catch(e) { console.error('즐겨찾기 로드 오류:', e); }
}

function loadBuiltinPdf(idx) {
  const pdf = DEFAULT_PDFS[idx]; if (!pdf) return;
  const exists = pdfTabs.findIndex(t => t.name === pdf.name);
  if (exists >= 0) { switchPdfTab(exists); return; }
  const binary = atob(pdf.base64);
  const bytes  = new Uint8Array(binary.length);
  for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
  const blob = new Blob([bytes], { type: 'application/pdf' });
  const url  = URL.createObjectURL(blob);
  pdfTabs.push({ name: pdf.name, url });
  switchPdfTab(pdfTabs.length - 1);
  showToast('⭐ ' + pdf.name + ' 열기 완료', 'blue');
}

async function loadPdfFromFav(name) {
  try {
    const db  = await openPdfDb();
    const req = db.transaction(PDF_STORE, 'readonly').objectStore(PDF_STORE).get(name);
    req.onsuccess = () => {
      const rec = req.result; if (!rec) return;
      const url = URL.createObjectURL(rec.blob);
      const exists = pdfTabs.findIndex(t => t.name === name);
      if (exists >= 0) { switchPdfTab(exists); return; }
      pdfTabs.push({ name, url });
      switchPdfTab(pdfTabs.length - 1);
      showToast('⭐ ' + name + ' 열기 완료', 'blue');
    };
  } catch(e) { showToast('⚠️ 파일 불러오기 실패', 'green'); }
}

async function togglePdfFav() {
  if (pdfActiveIdx < 0) return;
  const tab  = pdfTabs[pdfActiveIdx];
  const btn  = document.getElementById('pdfFavBtn');
  const favs = await getAllPdfFavs();
  const already = favs.find(f => f.name === tab.name);

  if (already) {
    await deletePdfFav(tab.name);
    btn.textContent = '☆ 등록';
    btn.style.color = '#fbbf24';
    showToast('즐겨찾기 해제됐어요', 'green');
  } else {
    // blob 재취득
    const res  = await fetch(tab.url);
    const blob = await res.blob();
    await savePdfFav(tab.name, blob);
    btn.textContent = '★ 등록됨';
    btn.style.color = '#f59e0b';
    showToast('⭐ 즐겨찾기 등록 완료!', 'blue');
  }
  loadPdfFavs();
}

async function removePdfFav(name) {
  await deletePdfFav(name);
  loadPdfFavs();
  // 현재 탭이 이 파일이면 버튼 초기화
  if (pdfActiveIdx >= 0 && pdfTabs[pdfActiveIdx]?.name === name) {
    const btn = document.getElementById('pdfFavBtn');
    if (btn) { btn.textContent = '☆ 등록'; btn.style.color = '#fbbf24'; }
  }
  showToast('즐겨찾기 삭제됐어요', 'green');
}

async function updateFavBtn() {
  const btn = document.getElementById('pdfFavBtn');
  if (!btn || pdfActiveIdx < 0) return;
  const tab  = pdfTabs[pdfActiveIdx];
  const favs = await getAllPdfFavs();
  const already = favs.find(f => f.name === tab.name);
  btn.style.display  = 'block';
  btn.textContent    = already ? '★ 등록됨' : '☆ 등록';
  btn.style.color    = already ? '#f59e0b' : '#fbbf24';
}

