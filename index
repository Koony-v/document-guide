// ── 미리보기 형식 전환 ──
let currentFormat = 'orig';

function convertFormat(text, type) {
  if (type === 'orig') return text;
  const lines = text.split('\n');
  let docNum = 0;
  return lines.map(line => {
    if (!line.startsWith('■ ')) return line;
    const content = line.slice(2);
    docNum++;
    if (type === 'check')    return '□ ' + content;
    if (type === 'num')      return docNum + '. ' + content;
    if (type === 'numcheck') return docNum + '. □ ' + content;
    if (type === 'dash')     return '- ' + content;
    return line;
  }).join('\n');
}

function getOrigText(text) {
  // 현재 형식 → ■ 원본으로 되돌리기
  const lines = text.split('\n');
  return lines.map(line => {
    if (line.match(/^\d+\.\s*□\s/)) return '■ ' + line.replace(/^\d+\.\s*□\s/, '');
    if (line.match(/^\d+\.\s/))      return '■ ' + line.replace(/^\d+\.\s/, '');
    if (line.startsWith('□ '))          return '■ ' + line.slice(2);
    if (line.startsWith('- '))          return '■ ' + line.slice(2);
    return line;
  }).join('\n');
}

function setFormat(type) {
  const preview = document.getElementById('kakaoPreview');
  const current = (preview.innerText || preview.textContent || '').trim();
  if (!current || current.includes('서류를 클릭하면')) return;

  // 현재 텍스트를 먼저 원본(■)으로 복원 후 새 형식 적용
  const orig = getOrigText(current);
  preview.textContent = convertFormat(orig, type);
  currentFormat = type;

